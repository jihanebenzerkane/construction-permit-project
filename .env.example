APP_NAME="Plateforme Permis de Construire"
APP_ENV=local
APP_DEBUG=true
APP_KEY=
APP_URL=http://localhost

# SQLite (recommandé en local si MySQL n’est pas démarré)
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# MySQL (XAMPP) — exemple si vous préférez MySQL :
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=plateforme_permis_construire
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync